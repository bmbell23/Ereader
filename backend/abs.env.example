# Audiobookshelf credentials for the Ereader backend.
#
# Copy this file to `abs.env` (same directory) and fill in ABS_TOKEN. run.sh
# sources abs.env automatically; abs.env is gitignored so the token never
# lands in the repo. Leave everything blank to keep audiobook support OFF —
# the library then falls back to the Calibre-only list.

# Personal API token from Audiobookshelf:
#   Settings -> Users -> (your user) -> "API Token".
ABS_TOKEN=

# Base URL of the Audiobookshelf server. Defaults to the local container
# (http://localhost:13378) when ABS_TOKEN is set and this is left blank.
# ABS_URL=http://localhost:13378

# Optional: pin a specific ABS library id. When blank the backend picks the
# first library whose mediaType is "book".
# ABS_LIBRARY_ID=
